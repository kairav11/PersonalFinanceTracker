# ============================================================
# Streamlit secrets template — for local dashboard development
# ============================================================
# Copy this file to .streamlit/secrets.toml at the project root
# and fill in your values:
#   cp dashboard/.streamlit/secrets.toml.example .streamlit/secrets.toml
#
# .streamlit/secrets.toml is listed in .gitignore — never commit it.
# For Streamlit Community Cloud, enter these values via:
#   App → ⋮ menu → Settings → Secrets
# ============================================================

# Databricks SQL Warehouse — use a read-only token scoped to gold.* only
DATABRICKS_HOST     = "your-workspace.cloud.databricks.com"
DATABRICKS_HTTP_PATH = "/sql/1.0/warehouses/your_warehouse_id"
DATABRICKS_TOKEN    = "dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
