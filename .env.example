# ============================================================
# Wealth-Flow Lakehouse — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is listed in .gitignore — never commit it.
# In GitHub Actions, all variables below are stored as Secrets.
# In Streamlit Community Cloud, DATABRICKS_* vars are added
# via the Secrets UI in the app settings.
# ============================================================

# ------------------------------------------------------------
# Databricks
# ------------------------------------------------------------
# Workspace hostname — Databricks UI → top-left workspace name → copy hostname only (no https://)
DATABRICKS_HOST=your-workspace.cloud.databricks.com

# Personal Access Token — Databricks UI → User Settings → Developer → Access Tokens → Generate
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SQL Warehouse HTTP Path — Databricks UI → SQL Warehouses → your warehouse → Connection details
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id

# ------------------------------------------------------------
# Google Sheets
# ------------------------------------------------------------
# Spreadsheet ID — the long string in the Sheet URL between /d/ and /edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Option A (local dev): path to the downloaded Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./ingestion/service_account.json

# Option B (CI/CD): full JSON content of the Service Account key as a single-line string
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Tab names in the Google Sheet — only change if you rename the tabs
GOOGLE_TRANSACTIONS_TAB=Transactions
GOOGLE_BUDGETS_TAB=Budgets

# ------------------------------------------------------------
# Ingestion — CSV file paths
# ------------------------------------------------------------
CSV_UPLOADS_DIR=./ingestion/csv_uploads
CSV_PROCESSED_DIR=./ingestion/csv_uploads/processed

# ------------------------------------------------------------
# dbt
# ------------------------------------------------------------
# Points dbt to the correct profiles.yml when running from the project root
DBT_PROFILES_DIR=./wealth_flow_dbt

# Use "dev" locally, "prod" in CI
DBT_TARGET=dev
